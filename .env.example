# Application
APP_ENV=development
APP_BASE_PATH=/LEMELANI_LOANS

# Database
DB_HOST=localhost
DB_NAME=lemelani_loans
DB_USER=root
DB_PASS=

# Outbound Email (Gmail SMTP with app password)
MAIL_FROM_ADDRESS=lemelani.loans.noreply@gmail.com
MAIL_FROM_NAME=Lemelani Loans
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USERNAME=lemelani.loans.noreply@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Hybrid Next.js rollout
NEXTJS_BASE_URL=http://localhost:3000
FILE_STORAGE_BACKEND=local
FF_NEXTJS_ALL=false
FF_NEXTJS_CUSTOMER_ALL=false
FF_NEXTJS_ADMIN_ALL=false
FF_NEXTJS_AUTH=false
FF_NEXTJS_DASHBOARD=false
FF_NEXTJS_LOANS=false
FF_NEXTJS_REPAYMENTS=false
FF_NEXTJS_PROFILE=false
FF_NEXTJS_CREDIT_HISTORY=false
FF_NEXTJS_NOTIFICATIONS=false
FF_NEXTJS_ADMIN_DASHBOARD=false
FF_NEXTJS_ADMIN_LOANS=false
FF_NEXTJS_ADMIN_USERS=false
FF_NEXTJS_ADMIN_VERIFICATIONS=false
FF_NEXTJS_ADMIN_PAYMENTS=false
FF_NEXTJS_ADMIN_SETTINGS=false
FF_NEXTJS_ADMIN_REPORTS=false
FF_NEXTJS_ADMIN_PLATFORM_ACCOUNTS=false

# Node workers
WORKER_DB_POOL_SIZE=5
WORKER_REMINDERS_DRY_RUN=true
WORKER_REMINDERS_INTERVAL_SECONDS=60
WORKER_REMINDER_WINDOW_DAYS=2
WORKER_ESCALATION_GRACE_DAYS=3
WORKER_SCORING_DRY_RUN=true
WORKER_SCORING_INTERVAL_SECONDS=600
WORKER_SCORING_STALE_DAYS=30
WORKER_SCORING_BATCH_LIMIT=200
WORKER_PAYMENTS_DRY_RUN=true
WORKER_PAYMENTS_INTERVAL_SECONDS=300
WORKER_PAYMENTS_IMPORT_DIR=c:/xampp/htdocs/LEMELANI_LOANS/workers/imports/payments
WORKER_PAYMENTS_ARCHIVE_DIR=c:/xampp/htdocs/LEMELANI_LOANS/workers/imports/archive

# Payment provider webhook ingestion secrets
WEBHOOK_SECRET_AIRTEL_MONEY=change_me_airtel_secret
WEBHOOK_SECRET_TNM_MPAMBA=change_me_tnm_secret
WEBHOOK_SECRET_CARD_GATEWAY=change_me_card_secret
WORKER_WEBHOOKS_DRY_RUN=true
WORKER_WEBHOOKS_INTERVAL_SECONDS=120
WORKER_WEBHOOKS_BATCH_LIMIT=100
